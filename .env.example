# ───────────────────────────────────────────────────────────────────
# Taksees — Environment variables
# Copy this file to `.env` and fill in real values.
# All variables are validated at boot by src/config/env.validation.ts.
# ───────────────────────────────────────────────────────────────────

# Runtime
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Database
DATABASE_URL=postgresql://taksees:taksees@localhost:5432/taksees?schema=public

# Redis (cache + queue broker)
REDIS_URL=redis://localhost:6379

# Storage (local volume)
STORAGE_DIR=./storage

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Throttler (per-route overrides exist in controllers)
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# VAPID keys (generate with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=BLc4xRzKlKORKWl...
VAPID_PRIVATE_KEY=replace-me
VAPID_SUBJECT=mailto:admin@taksees.app

# Token signing for signed local-file URLs
FILE_SIGNING_SECRET=change-me-to-a-32-byte-random-string

# ─── Google OAuth (Better Auth) ─────────────────────────────────
# Create at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: ${GOOGLE_REDIRECT_URI}
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/callback/google
# Restrict sign-in to a Google Workspace hosted domain. Leave
# empty to accept any Google account.
GOOGLE_WORKSPACE_HD=

# ─── Bootstrap (seed only) ──────────────────────────────────────
# Used by pnpm prisma:seed to create the first SUPER_ADMIN row
# via direct Prisma writes (NEVER through the API).
# In dev, this user can sign in via email/password (email/password
# is enabled when NODE_ENV != production).
# In production, the SUPER_ADMIN signs in with Google; their
# Google email must match BOOTSTRAP_SUPER_ADMIN_EMAIL.
# `openssl rand -base64 24` for a strong random password.
BOOTSTRAP_SUPER_ADMIN_EMAIL=admin@taksees.app
BOOTSTRAP_SUPER_ADMIN_NAME=System Admin
BOOTSTRAP_SUPER_ADMIN_PASSWORD=Passw0rd!
